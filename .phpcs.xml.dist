<?xml version="1.0"?>
<ruleset name="BP Redirect">
	<description>WordPress Coding Standards for BP Redirect plugin.</description>

	<arg name="extensions" value="php"/>
	<arg name="colors"/>
	<arg value="sp"/>

	<!-- Set minimum PHP version. -->
	<config name="minimum_supported_wp_version" value="5.0"/>
	<config name="testVersion" value="7.4-"/>

	<!-- Check the plugin directory. -->
	<file>.</file>

	<!-- Exclude paths. -->
	<exclude-pattern>node_modules/*</exclude-pattern>
	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>*.min.js</exclude-pattern>
	<exclude-pattern>*.min.css</exclude-pattern>
	<exclude-pattern>*.css.map</exclude-pattern>
	<exclude-pattern>*.lock</exclude-pattern>
	<exclude-pattern>package.json</exclude-pattern>
	<exclude-pattern>composer.json</exclude-pattern>

	<!-- Use WordPress-Extra as the base standard. -->
	<rule ref="WordPress-Extra">
		<!-- Exclude doc comment rules - not interested. -->
		<exclude name="Squiz.Commenting.FileComment"/>
		<exclude name="Squiz.Commenting.ClassComment"/>
		<exclude name="Squiz.Commenting.FunctionComment"/>
		<exclude name="Squiz.Commenting.VariableComment"/>
		<exclude name="Generic.Commenting.DocComment"/>
	</rule>

	<!-- Set text domain. -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="bp-redirect"/>
			</property>
		</properties>
	</rule>

	<!-- Allow short array syntax. -->
	<rule ref="Generic.Arrays.DisallowShortArraySyntax">
		<severity>0</severity>
	</rule>
</ruleset>
